# Streamlit Cloud の Secrets にこの内容を登録する。
# 既存の streamlit リポと同じ google_credentials / gspread_token を流用可能。

# Google OAuth (st.login 用) — Streamlit 1.42+ の標準機能
# 詳細: https://docs.streamlit.io/develop/concepts/connections/authentication
[auth]
redirect_uri = "https://<your-app>.streamlit.app/oauth2callback"
cookie_secret = "<openssl rand -hex 32 で生成>"

[auth.google]
client_id = "<google cloud console で発行した OAuth client id>"
client_secret = "<同 client secret>"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"


# gspread 用 OAuth credentials (アプリ側で Sheets を読み書きする識別)
# 既存の streamlit リポと同じ値でOK。
[google_credentials]
installed = { ... }  # 既存のものをそのままコピー

[gspread_token]
token = "..."
refresh_token = "..."
token_uri = "https://oauth2.googleapis.com/token"
client_id = "..."
client_secret = "..."
scopes = ["https://www.googleapis.com/auth/spreadsheets", "https://www.googleapis.com/auth/drive"]


# Amazon SP-API 認証情報 (Amazon出品管理ページで使用)
# 取得元: seller central → 開発者アカウント → LWA アプリ
[sp_api]
lwa_app_id      = "amzn1.application-oa2-client.xxx"
lwa_client_secret = "amzn1.oa2-cs.v1.xxx"
refresh_token   = "Atzr|xxx"
seller_id       = "AZENWJXLQ660S"
marketplace_id  = "A1VC38T7YXB528"

# Amazon せどりツール設定 (スプレッドシートID / Drive フォルダID)
[amazon_config]
spreadsheet_id        = "1Xb66vv997dWX9CIofuPNY23tuIQwoNFmm-hNBLbnBYo"
drive_image_folder_id = "1Mszsvbh9kSh1br_HB3fHIIkhdPVC0092"
bk_image_folder_id    = "1NTaFxO5l1hTOtqBX0PYyFPFZ88Eb6WbC"

# FBA 発送元住所 — sato アカウント
[sato_address]
name          = "佐藤サエ"
address_line1 = "新潟県新潟市東区牡丹山6-14-14-9ディセットハイム牡丹山206"
city          = "新潟市"
postal_code   = "9500872"
country_code  = "JP"

# FBA 発送元住所 — kudo アカウント
[kudo_address]
